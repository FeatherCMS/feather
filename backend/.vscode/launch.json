{
  "configurations": [
    {
      "type": "swift",
      "request": "launch",
      "args": ["--env-file-path", "./configs/server.example.env"],
      "cwd": "${workspaceFolder:backend}",
      "name": "Debug Server",
      "target": "Server",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug Server",
    },
    {
      "type": "swift",
      "request": "launch",
      "args": ["--env-file-path", "./configs/server.example.env"],
      "cwd": "${workspaceFolder:backend}",
      "name": "Release Server",
      "target": "Server",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release Server",
    },
    {
      "type": "swift",
      "request": "launch",
      "args": ["--env-file-path", "./configs/migrator.example.env"],
      "cwd": "${workspaceFolder:backend}",
      "name": "Debug Migrator",
      "target": "Migrator",
      "configuration": "debug",
      "preLaunchTask": "swift: Build Debug Migrator",
    },
    {
      "type": "swift",
      "request": "launch",
      "args": ["--env-file-path", "./configs/migrator.example.env"],
      "cwd": "${workspaceFolder:backend}",
      "name": "Release Migrator",
      "target": "Migrator",
      "configuration": "release",
      "preLaunchTask": "swift: Build Release Migrator",
    },
  ],
}
